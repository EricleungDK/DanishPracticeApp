{
  "name": "danish-practice-generator",
  "productName": "Danish Practice Generator",
  "version": "1.0.2",
  "description": "Desktop app for practicing Danish at B1-B2 level with spaced repetition",
  "main": ".vite/build/index.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform win32 --arch x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build --config vite.config.web.ts",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:android": "npm run build:web && npx cap sync android && npx cap open android",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "danish",
    "language-learning",
    "spaced-repetition",
    "electron"
  ],
  "author": {
    "name": "ericleungDK",
    "email": "ericleung218@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "41.0.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.3.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "capacitor-plugin-safe-area": "^5.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.7"
  }
}
